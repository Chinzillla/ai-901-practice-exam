{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/questions.json"]
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/questions.json",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    }
  ],
  "mimeTypes": {
    ".json": "application/json"
  }
}
